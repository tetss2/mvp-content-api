# Runtime selection
NODE_ENV=production
RUNTIME_MODE=beta
RUNTIME_NAME=mvp-content-api-beta
TELEGRAM_POLLING=true
START_LEADS_BOT=false

# Production bot token for non-beta runtimes
TELEGRAM_TOKEN=

# Required in RUNTIME_MODE=beta/staging/railway-beta.
# Use a separate Telegram bot from the current MVP-DI-1 production bot.
TELEGRAM_BETA_TOKEN=

OPENAI_API_KEY=
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
FALAI_KEY=
CLOUDINARY_CLOUD=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Optional Railway/staging path overrides. Defaults isolate beta under runtime-data/beta.
RUNTIME_DATA_ROOT=
USERS_ROOT=
BETA_TELEMETRY_DIR=
DEMO_DB_PATH=
KNOWLEDGE_INTAKE_ROOT=
USERS_DB_PATH=
MAX_UPLOAD_MB=12

# Telegram Stars payments. XTR invoices use an empty provider token internally.
TELEGRAM_STARS_ENABLED=false
PLAN_START_STARS_PRICE=149
PLAN_PRO_STARS_PRICE=499
PLAN_START_TEXT_LIMIT=50
PLAN_PRO_TEXT_LIMIT=200

ENABLE_KB_RETRIEVAL=false
KB_TOP_K=5
KB_MAX_CONTEXT_TOKENS=2500
KB_MAX_CHUNKS_PER_SOURCE=2
KB_DEDUP_ENABLED=true
KB_RERANK_ENABLED=true
KB_QUALITY_FILTER_ENABLED=true
