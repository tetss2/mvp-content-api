{
  "name": "mvp-content-api",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "index": "node scripts/indexer.js",
    "kb:ingest": "node knowledge_ingest.js",
    "kb:promote:dry": "node knowledge_promote.js --dry-run",
    "kb:promote": "node knowledge_promote.js --promote",
    "kb:rollback:latest": "node knowledge_promote.js --rollback-latest",
    "kb:validate:production": "node knowledge_promote.js --validate-production",
    "kb:retrieve": "node knowledge_retrieval.js --retrieve",
    "kb:extract:sexologist": "node scripts/extract-sexologist.js",
    "kb:classify:sexologist": "node scripts/classify-sexologist.js",
    "kb:reclassify:sexologist": "node scripts/reclassify-sexologist-review.js",
    "kb:ingest:sexologist:classified:dry": "node knowledge_ingest.js --kb sexologist --classified-intake --dry-run",
    "kb:ingest:sexologist:classified:apply": "node knowledge_ingest.js --kb sexologist --classified-intake --apply",
    "kb:validate:sexologist:staging": "node knowledge_ingest.js --kb sexologist --validate-staging",
    "kb:test:sexologist:staging:retrieval": "node scripts/test-sexologist-staging-retrieval.js",
    "kb:test:sexologist:production:retrieval": "node scripts/test-sexologist-production-retrieval.js",
    "kb:test:sexologist:live-retrieval": "node scripts/test-live-sexologist-retrieval.js",
    "kb:test:sexologist:full-response": "node scripts/test-full-sexologist-response.js",
    "kb:evaluate:sexologist:retrieval": "node scripts/evaluate-sexologist-retrieval.js",
    "kb:report:dinara:sexologist": "node scripts/generate-dinara-batch-report.js",
    "author:analyze:dinara": "node scripts/analyze-author-voice.js --author dinara",
    "expert:dinara:inventory": "node scripts/expert-onboarding-inventory.js --expert dinara",
    "expert:dinara:prepare-sources": "node scripts/expert-knowledge-source-prepare.js --expert dinara",
    "expert:dinara:voice": "node scripts/expert-author-voice-intake.js --expert dinara",
    "expert:dinara:onboard": "npm run expert:dinara:inventory && npm run expert:dinara:prepare-sources && npm run expert:dinara:voice && npm run kb:report:dinara:sexologist",
    "kb:test:ingest": "node scripts/safe-cleaned-kb-ingest-test.js",
    "kb:test:ingest:dry": "node scripts/safe-cleaned-kb-ingest-test.js --dry-run",
    "kb:test:retrieve": "node scripts/safe-cleaned-kb-retrieval-test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "mammoth": "^1.6.0",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.61.0",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1"
  }
}
